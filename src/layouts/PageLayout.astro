---
import BaseLayout from './BaseLayout.astro';
import Header from '../components/layout/Header.astro';
import Footer from '../components/layout/Footer.astro';

export interface Props {
  title: string;
  description: string;
  image?: string;
  jsonLd?: object;
  overlayHeader?: boolean;
  darkHero?: boolean;
  noindex?: boolean;
}

const { overlayHeader = false, darkHero = false, noindex = false, ...rest } = Astro.props;
---
<BaseLayout {...rest} darkHero={darkHero} noindex={noindex}>
  <Header transparent={overlayHeader} />
  <main id="main-content" tabindex="-1" class:list={[!overlayHeader && 'main--offset']}>
    <slot />
  </main>
  <Footer />
</BaseLayout>

<style>
  /* Compensate for fixed header on pages that don't overlay it */
  .main--offset {
    padding-top: 4.5rem;
  }
</style>
