---
import { ClientRouter } from 'astro:transitions';
import '../styles/global.css';
import '../styles/animations.css';

export interface Props {
  title: string;
  description: string;
  image?: string;
  jsonLd?: object;
  darkHero?: boolean;
}

const {
  title,
  description,
  image = '/og-default.jpg',
  jsonLd,
  darkHero = false,
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site ?? 'https://studioweare.fr');
---
<!doctype html>
<html lang="fr" data-theme="light">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="canonical" href={canonicalURL} />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={new URL(image, Astro.site ?? 'https://studioweare.fr')} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:type" content="website" />
    <meta name="twitter:card" content="summary_large_image" />
    {jsonLd && (
      <script is:inline type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
    )}
    <link rel="icon" type="image/png" href="/favicon.png" />
    <ClientRouter />
    <script is:inline>
      // Apply theme before paint — also re-applied after each View Transition swap
      function applyTheme() {
        var stored = localStorage.getItem('theme');
        var prefersDark = window.matchMedia('(prefers-color-scheme: light)').matches;
        document.documentElement.setAttribute(
          'data-theme',
          stored ?? 'light'
        );
      }
      applyTheme();
      document.addEventListener('astro:after-swap', applyTheme);
    </script>
  </head>
  <body class:list={[darkHero && 'body--dark-hero']}>
    <slot />
    <script>
      const reducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

      let lenis: any = null;

      async function initLenis() {
        if (reducedMotion) return;
        const { default: Lenis } = await import('lenis');
        lenis?.destroy();
        lenis = new Lenis({
          duration: 1.2,
          easing: (t: number) => Math.min(1, 1.001 - Math.pow(2, -10 * t)),
          touchMultiplier: 1.5,
        });
        function raf(time: number) {
          lenis.raf(time);
          requestAnimationFrame(raf);
        }
        requestAnimationFrame(raf);
      }

      function initObserver() {
        const animEls = document.querySelectorAll('.animate-fade:not(.is-visible), .animate-slide:not(.is-visible)');
        const observer = new IntersectionObserver(
          (entries) => {
            entries.forEach((e) => {
              if (e.isIntersecting) {
                e.target.classList.add('is-visible');
                observer.unobserve(e.target);
              }
            });
          },
          { threshold: 0.12 }
        );
        animEls.forEach((el) => observer.observe(el));
      }

      initLenis();
      initObserver();

      document.addEventListener('astro:page-load', () => {
        initLenis();
        initObserver();
        if (lenis) {
          lenis.scrollTo(0, { immediate: true });
        }
      });

      document.addEventListener('astro:after-swap', () => {
        window.scrollTo(0, 0);
      });
    </script>
  </body>
</html>

<style>
  /* Dark body background for pages with a dark hero — only visible during view transitions */
  .body--dark-hero {
    background-color: #0a0805;
  }
</style>
