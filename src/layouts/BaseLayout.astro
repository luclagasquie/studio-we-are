---
import { ClientRouter } from 'astro:transitions';
import '../styles/global.css';
import '../styles/animations.css';

export interface Props {
  title: string;
  description: string;
  image?: string;
  jsonLd?: object;
}

const {
  title,
  description,
  image = '/og-default.jpg',
  jsonLd,
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site ?? 'https://studioweare.fr');
---
<!doctype html>
<html lang="fr" data-theme="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="canonical" href={canonicalURL} />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={new URL(image, Astro.site ?? 'https://studioweare.fr')} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:type" content="website" />
    <meta name="twitter:card" content="summary_large_image" />
    {jsonLd && (
      <script is:inline type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
    )}
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;1,300;1,400&family=DM+Sans:opsz,wght@9..40,300;9..40,400;9..40,500&display=swap"
    />
    <ClientRouter />
    <script is:inline>
      // Apply theme before paint — also re-applied after each View Transition swap
      function applyTheme() {
        var stored = localStorage.getItem('theme');
        var prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
        document.documentElement.setAttribute(
          'data-theme',
          stored ?? 'dark'
        );
      }
      applyTheme();
      document.addEventListener('astro:after-swap', applyTheme);
    </script>
  </head>
  <body>
    <slot />
    <script>
      import Lenis from 'lenis';

      const reducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

      let lenis: InstanceType<typeof Lenis> | null = null;

      function initLenis() {
        if (reducedMotion) return;
        lenis?.destroy();
        lenis = new Lenis({
          duration: 1.2,
          easing: (t: number) => Math.min(1, 1.001 - Math.pow(2, -10 * t)),
          touchMultiplier: 1.5,
        });
        function raf(time: number) {
          lenis!.raf(time);
          requestAnimationFrame(raf);
        }
        requestAnimationFrame(raf);
      }

      function initObserver() {
        const animEls = document.querySelectorAll('.animate-fade:not(.is-visible), .animate-slide:not(.is-visible)');
        const observer = new IntersectionObserver(
          (entries) => {
            entries.forEach((e) => {
              if (e.isIntersecting) {
                e.target.classList.add('is-visible');
                observer.unobserve(e.target);
              }
            });
          },
          { threshold: 0.12 }
        );
        animEls.forEach((el) => observer.observe(el));
      }

      // Initial load
      initLenis();
      initObserver();

      // After each View Transition
      document.addEventListener('astro:page-load', () => {
        initLenis();
        initObserver();
      });
    </script>
  </body>
</html>
