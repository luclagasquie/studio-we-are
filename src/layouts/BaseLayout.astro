---
import { ClientRouter } from 'astro:transitions';
import '../styles/global.css';
import '../styles/animations.css';
import ogImage from '../assets/about/og-image.jpg';

export interface Props {
  title: string;
  description: string;
  image?: string;
  jsonLd?: object;
  darkHero?: boolean;
}

const {
  title,
  description,
  image,
  jsonLd,
  darkHero = false,
} = Astro.props;

const SITE = Astro.site ?? 'https://we-are.fr';
const canonicalURL = new URL(Astro.url.pathname, SITE);

const ogImageUrl = image
  ? new URL(image, SITE).href
  : ogImage.src.startsWith('http')
    ? ogImage.src
    : new URL(ogImage.src, SITE).href;

const defaultJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: 'Studio We Are',
  url: SITE,
  description,
};
---
<!doctype html>
<html lang="fr" data-theme="light">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="canonical" href={canonicalURL} />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:type" content="website" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />
    <script is:inline type="application/ld+json" set:html={JSON.stringify(defaultJsonLd)} />
    {jsonLd && (
      <script is:inline type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
    )}
    <link rel="icon" type="image/png" href="/favicon.png" />
    <ClientRouter />
    <script is:inline>
      function applyTheme() {
        var stored = localStorage.getItem('theme');
        var prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
        var theme = (stored === 'dark' || stored === 'light') ? stored : (prefersDark ? 'dark' : 'light');
        document.documentElement.setAttribute(
          'data-theme',
          theme
        );
      }
      applyTheme();
      document.addEventListener('astro:after-swap', applyTheme);
    </script>
  </head>
  <body class:list={[darkHero && 'body--dark-hero']}>
    <slot />
    <script>
      function isReducedMotion() {
        return window.matchMedia('(prefers-reduced-motion: reduce)').matches;
      }

      let lenis: any = null;

      async function initLenis() {
        if (isReducedMotion()) return;
        const { default: Lenis } = await import('lenis');
        lenis?.destroy();
        lenis = new Lenis({
          duration: 1.2,
          easing: (t: number) => Math.min(1, 1.001 - Math.pow(2, -10 * t)),
          touchMultiplier: 1.5,
        });
        function raf(time: number) {
          lenis.raf(time);
          requestAnimationFrame(raf);
        }
        requestAnimationFrame(raf);
      }

      function initObserver() {
        const animEls = document.querySelectorAll('.animate-fade:not(.is-visible), .animate-slide:not(.is-visible)');
        const observer = new IntersectionObserver(
          (entries) => {
            entries.forEach((e) => {
              if (e.isIntersecting) {
                e.target.classList.add('is-visible');
                observer.unobserve(e.target);
              }
            });
          },
          { threshold: 0.12 }
        );
        animEls.forEach((el) => observer.observe(el));
      }

      function initImageShimmer() {
        const containers = document.querySelectorAll('.image-shimmer:not(.is-loaded)');
        containers.forEach((container) => {
          const img = container.querySelector('img');
          if (!img) return;
          if (img.complete && img.naturalHeight > 0) {
            container.classList.add('is-loaded');
          } else {
            img.addEventListener('load', () => container.classList.add('is-loaded'), { once: true });
            img.addEventListener('error', () => container.classList.add('is-loaded'), { once: true });
          }
        });
      }

      initLenis();
      initObserver();
      initImageShimmer();

      document.addEventListener('astro:page-load', () => {
        initLenis();
        initObserver();
        initImageShimmer();
        if (lenis) {
          lenis.scrollTo(0, { immediate: true });
        }
      });

      document.addEventListener('astro:after-swap', () => {
        window.scrollTo(0, 0);
      });
    </script>
  </body>
</html>

<style>
  .body--dark-hero {
    background-color: #0a0805;
  }
</style>
