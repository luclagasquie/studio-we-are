---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';
import Badge from '../ui/Badge.astro';

export interface Props {
  title: string;
  description: string;
  secteur: string;
  type: string;
  stack: string[];
  url?: string;
  image?: ImageMetadata;
  logo?: ImageMetadata;
  slug: string;
  stagger?: number;
  reverse?: boolean;
  index?: number;
}

const {
  title,
  description,
  secteur,
  type,
  stack,
  url,
  image,
  logo,
  slug,
  stagger = 0,
  reverse = false,
  index = 0,
  ...rest
} = Astro.props;

const num = String(index + 1).padStart(2, '0');

const typeLabel: Record<string, string> = {
  vitrine: 'Vitrine',
  'e-commerce': 'E-commerce',
  wordpress: 'WordPress',
  astro: 'Astro',
  headless: 'Headless',
};
---

<article
  class:list={[
    'project-strip',
    'animate-slide',
    stagger > 0 && `stagger-${stagger}`,
    reverse && 'project-strip--reverse',
  ]}
  aria-label={`Projet : ${title}`}
  {...rest}
>
  <!-- IMAGE AREA -->
  <div class="project-strip__visual">
    {image ? (
      <Image
        src={image}
        alt={`Capture du projet ${title}`}
        class="project-strip__img"
        loading="lazy"
        decoding="async"
        widths={[480, 800, 1200]}
        sizes="(max-width: 768px) 100vw, 42vw"
      />
    ) : (
      <div class="project-strip__placeholder" aria-hidden="true">
        <span class="project-strip__type-deco">{typeLabel[type] ?? type}</span>
        <span class="project-strip__num">{num}</span>
      </div>
    )}
  </div>

  <!-- CONTENT AREA -->
  <div class="project-strip__content">
    <div class="project-strip__meta">
      <div class="project-strip__header">
        <span class="project-strip__sector">{secteur}</span>
        <h3 class="project-strip__title">{title}</h3>
      </div>
      <div class="project-strip__logo-wrap">
        {logo ? (
          <Image
            src={logo}
            alt={`Logo ${title}`}
            class="project-strip__logo"
            height={128}
            width={logo.width * (128 / logo.height)}
          />
        ) : (
          <span class="project-strip__monogram" aria-hidden="true">
            {title.substring(0, 2).toUpperCase()}
          </span>
        )}
      </div>
    </div>

    
    <p class="project-strip__desc">{description}</p>

    <div class="project-strip__stack">
      {stack.map((s) => <Badge label={s} />)}
    </div>

    {url && (
      <a
        href={url}
        target="_blank"
        rel="noopener noreferrer"
        class="project-strip__link"
        aria-label={`Visiter le site — ${title}`}
      >
        Voir le site <span aria-hidden="true">→</span>
      </a>
    )}
  </div>
</article>

<style>
  /* ─── Strip container ─────────────────────────────── */
  .project-strip {
    display: grid;
    grid-template-columns: 42% 1fr;
    min-height: 420px;
    border-top: 1px solid var(--border);
    position: relative;
    overflow: hidden;
    padding-block: clamp(2rem, 4vw, 3.5rem);
    transition: border-color var(--transition);
  }

  .project-strip:last-child {
    border-bottom: 1px solid var(--border);
  }

  /* Accent bar that slides in on hover — scoped to the image */
  .project-strip__visual::before {
    content: '';
    position: absolute;
    inset-block: 0;
    left: 0;
    width: 1px;
    background: var(--accent);
    transform: scaleY(0);
    transform-origin: bottom;
    transition: transform 0.45s cubic-bezier(0.16, 1, 0.3, 1);
    z-index: 2;
  }

  .project-strip:hover .project-strip__visual::before {
    transform: scaleY(1);
  }

  /* Reversed layout */
  .project-strip--reverse {
    grid-template-columns: 1fr 42%;
  }

  .project-strip--reverse .project-strip__visual {
    order: 2;
  }

  .project-strip--reverse .project-strip__content {
    order: 1;
  }

  /* ─── Visual area ─────────────────────────────────── */
  .project-strip__visual {
    position: relative;
    overflow: hidden;
  }

  .project-strip__img {
    width: 100%;
    height: 100%;
    aspect-ratio: 4 / 3;
    object-fit: cover;
    display: block;
    transition: transform 1s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .project-strip:hover .project-strip__img {
    transform: scale(1.03);
  }

  /* ─── Placeholder ────────────────────────────────── */
  .project-strip__placeholder {
    width: 100%;
    height: 100%;
    aspect-ratio: 4 / 3;
    background: linear-gradient(
      135deg,
      var(--bg-alt) 0%,
      color-mix(in srgb, var(--accent) 8%, var(--bg-alt)) 100%
    );
    display: flex;
    align-items: flex-end;
    justify-content: flex-start;
    padding: 2rem;
    position: relative;
    overflow: hidden;
  }

  /* Large decorative type label */
  .project-strip__type-deco {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%) rotate(-6deg);
    font-family: var(--font-display);
    font-size: clamp(3rem, 6vw, 5.5rem);
    font-weight: 300;
    font-style: italic;
    color: color-mix(in srgb, var(--accent) 18%, transparent);
    white-space: nowrap;
    pointer-events: none;
    user-select: none;
    letter-spacing: -0.02em;
    transition: opacity 0.4s ease;
  }

  .project-strip:hover .project-strip__type-deco {
    opacity: 0.6;
  }

  /* Editorial index number */
  .project-strip__num {
    font-family: var(--font-display);
    font-size: 0.8125rem;
    font-weight: 400;
    letter-spacing: 0.12em;
    color: var(--text-muted);
    position: relative;
    z-index: 1;
  }

  /* ─── Content area ───────────────────────────────── */
  .project-strip__content {
    padding: clamp(2rem, 4vw, 3.5rem) clamp(2rem, 4vw, 3.5rem);
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 1.25rem;
    position: relative;
  }

  /* Subtle separator between visual + content */
  .project-strip__visual::after {
    content: '';
    position: absolute;
    inset-block: 0;
    right: 0;
    width: 1px;
    background: var(--border);
  }

  .project-strip--reverse .project-strip__visual::after {
    right: auto;
    left: 0;
  }

  /* ─── Meta row ────────────────────────────────────── */
  .project-strip__meta {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
  }

  .project-strip__sector {
    font-size: 0.6875rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--accent);
    font-family: var(--font-body);
    font-weight: 500;
  }

  /* ─── Logo / monogram ────────────────────────────── */
  .project-strip__logo-wrap {
    flex-shrink: 0;
  }

  .project-strip__logo {
    height: 64px;
    width: auto;
    object-fit: contain;
    filter: grayscale(1);
    opacity: 0.6;
    transition: filter var(--transition), opacity var(--transition);
  }

  .project-strip:hover .project-strip__logo {
    filter: grayscale(0);
    opacity: 1;
  }

  .project-strip__monogram {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 44px;
    height: 44px;
    border: 1px solid var(--border);
    font-family: var(--font-display);
    font-size: 1.125rem;
    font-weight: 300;
    letter-spacing: 0.05em;
    color: var(--text-muted);
    transition: border-color var(--transition), color var(--transition);
  }

  .project-strip:hover .project-strip__monogram {
    border-color: var(--accent);
    color: var(--accent);
  }

  /* ─── Title ──────────────────────────────────────── */

  .project-strip__header {
    display: flex;
    flex-direction: column;
    gap: .5em;
  }

  .project-strip__title {
    font-family: var(--font-display);
    font-size: clamp(1.75rem, 2.5vw, 2.5rem);
    max-width: 18ch;
    font-weight: 400;
    line-height: 1.1;
    letter-spacing: -0.02em;
    margin: 0;
    transition: color var(--transition);
  }

  .project-strip:hover .project-strip__title {
    color: var(--accent);
  }

  /* ─── Description ────────────────────────────────── */
  .project-strip__desc {
    color: var(--text-muted);
    font-size: 0.9375rem;
    line-height: 1.65;
    max-width: 52ch;
  }

  /* ─── Stack badges ───────────────────────────────── */
  .project-strip__stack {
    display: flex;
    gap: 0.4rem;
    flex-wrap: wrap;
  }

  /* ─── External link ──────────────────────────────── */
  .project-strip__link {
    display: inline-flex;
    align-items: center;
    gap: 0.4em;
    font-size: 0.8125rem;
    font-weight: 500;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--text-muted);
    font-family: var(--font-body);
    padding-top: 1rem;
    border-top: 1px solid var(--border);
    margin-top: auto;
    transition: color var(--transition), gap var(--transition);
    width: fit-content;
  }

  .project-strip__link:hover {
    color: var(--accent);
    gap: 0.7em;
  }

  /* ─── Responsive ─────────────────────────────────── */
  @media (max-width: 768px) {
    .project-strip,
    .project-strip--reverse {
      grid-template-columns: 1fr;
      min-height: unset;
    }

    .project-strip--reverse .project-strip__visual {
      order: unset;
    }

    .project-strip--reverse .project-strip__content {
      order: unset;
    }

    .project-strip__visual {
      height: 260px;
    }

    .project-strip__visual::after {
      inset-block: auto;
      bottom: 0;
      right: 0;
      left: 0;
      width: 100%;
      height: 1px;
    }

    .project-strip--reverse .project-strip__visual::after {
      inset-block: auto;
      bottom: 0;
      left: 0;
      width: 100%;
      height: 1px;
    }

    .project-strip__visual::before {
      inset-block: auto;
      top: 0;
      inset-inline: 0;
      width: 100%;
      height: 1px;
      transform: scaleX(0);
      transform-origin: left;
    }

    .project-strip:hover .project-strip__visual::before {
      transform: scaleX(1);
    }
  }
</style>
