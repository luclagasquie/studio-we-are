---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';
import type { HTMLAttributes } from 'astro/types';
import Badge from '../ui/Badge.astro';

export interface Props extends HTMLAttributes<'article'> {
  title: string;
  description: string;
  secteur: string;
  lieu: string;
  venteEnLigne: boolean;
  design: boolean;
  developpement: boolean;
  collaborateur?: string;
  image?: ImageMetadata;
  slug: string;
  siteUrl?: string;
  stagger?: number;
  reverse?: boolean;
  index?: number;
}

const {
  title,
  description,
  secteur,
  lieu,
  venteEnLigne,
  design,
  developpement,
  collaborateur,
  image,
  slug,
  siteUrl,
  stagger = 0,
  reverse = false,
  index = 0,
  ...rest
} = Astro.props;

const num = String(index + 1).padStart(2, '0');

const services: string[] = [];
if (design) services.push('Design');
if (developpement) services.push('Développement');
if (venteEnLigne) services.push('E-commerce');
---

<article
  class:list={[
    'project-strip',
    'animate-slide',
    stagger > 0 && `stagger-${stagger}`,
    reverse && 'project-strip--reverse',
  ]}
  aria-label={`Projet : ${title}`}
  {...rest}
>
  <!-- IMAGE AREA -->
  <div class="project-strip__visual">
    {image ? (
      <Image
        src={image}
        alt={`Capture du projet ${title}`}
        class="project-strip__img"
        loading="lazy"
        decoding="async"
        widths={[480, 800, 1200]}
        sizes="(max-width: 768px) 100vw, 42vw"
      />
    ) : (
      <div class="project-strip__placeholder" aria-hidden="true">
        <span class="project-strip__type-deco">{secteur}</span>
        <span class="project-strip__num">{num}</span>
      </div>
    )}
  </div>

  <!-- CONTENT AREA -->
  <div class="project-strip__content">
    <div class="project-strip__meta">
      <div class="project-strip__header">
        <span class="project-strip__sector">{secteur}</span>
        <h3 class="project-strip__title">{title}</h3>
      </div>

    </div>

    <div class="project-strip__link-wrapper">
      <p class="project-strip__lieu"><svg class="project-strip__lieu-icon" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 1 1 16 0Z"/><circle cx="12" cy="10" r="3"/></svg>{lieu}</p>

    {siteUrl && (
      <a href={siteUrl} target="_blank" rel="noopener noreferrer" aria-label={`voir le site de ${title}`} class="project-strip__link">
        <svg class="project-strip__link-globe-icon" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <circle cx="12" cy="12" r="10"/>
          <line x1="2" y1="12" x2="22" y2="12"/>
          <path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/>
        </svg>
        <span class="project-strip__link-text" aria-hidden="true">Voir le site</span>
        <svg class="project-strip__link-icon" width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M7 17L17 7"/>
          <path d="M7 7h10v10"/>
        </svg>
      </a>
    )}
    </div>

    <p class="project-strip__desc">{description}</p>

    <div class="project-strip__badges">
      {services.map((s) => <Badge label={s} />)}
      {collaborateur && collaborateur.length > 0 && (
        <Badge label={collaborateur} variant="collaborateur" />
      )}
    </div>

    
  </div>
</article>

<style>
  /* ─── Strip container ─────────────────────────────── */
  .project-strip {
    display: grid;
    grid-template-columns: 42% 1fr;
    min-height: 420px;
    border-top: 1px solid var(--border);
    position: relative;
    overflow: hidden;
    padding-block: clamp(2rem, 4vw, 3.5rem);
    transition: border-color var(--transition);
    align-items: center;
  }

  .project-strip:last-child {
    border-bottom: 1px solid var(--border);
  }

  /* Reversed layout */
  .project-strip--reverse {
    grid-template-columns: 1fr 42%;
  }

  .project-strip--reverse .project-strip__visual {
    order: 2;
  }

  .project-strip--reverse .project-strip__content {
    order: 1;
  }

  /* ─── Visual area ─────────────────────────────────── */
  .project-strip__visual {
    position: relative;
    overflow: hidden;
    aspect-ratio: 4 / 3;
  }

  .project-strip__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: all 1s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .project-strip:hover .project-strip__img {
    transform: scale(1.03);
  }

  @media (width > 900px) {
    .project-strip__img {
      filter: grayscale(1);
    }

    .project-strip:hover .project-strip__img {
      filter: grayscale(0);
    }
  }

  /* ─── Placeholder ────────────────────────────────── */
  .project-strip__placeholder {
    width: 100%;
    height: 100%;
    background: linear-gradient(
      135deg,
      var(--bg-alt) 0%,
      color-mix(in srgb, var(--accent) 8%, var(--bg-alt)) 100%
    );
    display: flex;
    align-items: flex-end;
    justify-content: flex-start;
    padding: 2rem;
    position: relative;
    overflow: hidden;
  }

  /* Large decorative type label */
  .project-strip__type-deco {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%) rotate(-6deg);
    font-family: var(--font-display);
    font-size: clamp(3rem, 6vw, 5.5rem);
    font-weight: 300;
    font-style: italic;
    color: color-mix(in srgb, var(--accent) 18%, transparent);
    white-space: nowrap;
    pointer-events: none;
    user-select: none;
    letter-spacing: -0.02em;
    transition: opacity 0.4s ease;
  }

  .project-strip:hover .project-strip__type-deco {
    opacity: 0.6;
  }

  /* Editorial index number */
  .project-strip__num {
    font-family: var(--font-display);
    font-size: 0.8125rem;
    font-weight: 400;
    letter-spacing: 0.12em;
    color: var(--text-muted);
    position: relative;
    z-index: 1;
  }

  /* ─── Content area ───────────────────────────────── */
  .project-strip__content {
    padding: clamp(2rem, 4vw, 3.5rem) clamp(2rem, 4vw, 3.5rem);
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 1.25rem;
    position: relative;
  }

  @media (width <= 768px) {
    .project-strip__content {
      padding: clamp(2rem, 4vw, 3.5rem) 0;
    }
  }

  .project-strip--reverse .project-strip__visual::after {
    right: auto;
    left: 0;
  }

  /* ─── Meta row ────────────────────────────────────── */
  .project-strip__meta {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
  }

  .project-strip__sector {
    font-size: calc(var(--text-s) * 0.9);
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--accent);
    font-family: var(--font-body);
    font-weight: 500;
  }

  /* ─── Title ──────────────────────────────────────── */

  .project-strip__header {
    display: flex;
    flex-direction: column;
    gap: .5em;
  }

  .project-strip__title {
    font-family: var(--font-display);
    font-size: calc(var(--heading-l) * 1.25);
    max-width: 18ch;
    font-weight: 400;
    line-height: 1.1;
    letter-spacing: -0.02em;
    margin: 0;
    transition: color var(--transition);
  }

  .project-strip:hover .project-strip__title {
    color: var(--accent);
  }

  /* ─── Lieu ────────────────────────────────────────── */
  .project-strip__lieu {
    font-size: var(--text-s);
    color: var(--text-muted);
    font-family: var(--font-body);
    font-weight: 400;
    display: flex;
    align-items: center;
    gap: 0.35em;
  }

  .project-strip__lieu-icon {
    flex-shrink: 0;
  }

  .project-strip__link-wrapper {
    display: flex;
    flex-direction: row;
    align-items: center;
    gap: 1.25rem;
  }

  /* ─── Description ────────────────────────────────── */
  .project-strip__desc {
    color: var(--text-muted);
    font-size: var(--text-m);
    line-height: 1.65;
    max-width: 52ch;
  }

  /* ─── Badges ──────────────────────────────────────── */
  .project-strip__badges {
    display: flex;
    gap: 0.4rem;
    flex-wrap: wrap;
  }

  /* ─── Link "Voir le site" ─────────────────────────── */
  .project-strip__link {
    display: inline-flex;
    align-items: center;
    gap: 0.35em;
    font-size: var(--text-s);
    font-family: var(--font-body);
    font-weight: 500;
    color: var(--text-muted);
    transition: color var(--transition);
    align-self: flex-start;
    letter-spacing: -0.02em;
  }

  .project-strip__link:hover {
    text-decoration: underline;
    text-decoration-thickness: 1px;
    text-underline-offset: 0.2em;
    color: var(--accent);
  }

  .project-strip__link-text {
    transition: transform 0.3s ease;
  }

  .project-strip__link-icon {
    flex-shrink: 0;
    transition: transform 0.3s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .project-strip__link-globe-icon {
    flex-shrink: 0;
  }

  .project-strip__link:hover .project-strip__link-icon {
    transform: rotate(45deg);
  }

  /* ─── Responsive ─────────────────────────────────── */
  @media (max-width: 768px) {
    .project-strip,
    .project-strip--reverse {
      grid-template-columns: 1fr;
      min-height: unset;
    }

    .project-strip--reverse .project-strip__visual {
      order: unset;
    }

    .project-strip--reverse .project-strip__content {
      order: unset;
    }

    .project-strip__visual::after {
      inset-block: auto;
      bottom: 0;
      right: 0;
      left: 0;
      width: 100%;
      height: 1px;
    }

    .project-strip--reverse .project-strip__visual::after {
      inset-block: auto;
      bottom: 0;
      left: 0;
      width: 100%;
      height: 1px;
    }

    .project-strip__visual::before {
      inset-block: auto;
      top: 0;
      inset-inline: 0;
      width: 100%;
      height: 1px;
      transform: scaleX(0);
      transform-origin: left;
    }

    .project-strip:hover .project-strip__visual::before {
      transform: scaleX(1);
    }
  }
</style>
