---
import Badge from '../ui/Badge.astro';

export interface Props {
  title: string;
  description: string;
  secteur: string;
  stack: string[];
  slug: string;
  draft?: boolean;
  stagger?: number;
}

const { title, description, secteur, stack, slug, draft = false, stagger = 0 } = Astro.props;
---
<article class:list={['project-card', 'animate-slide', stagger > 0 && `stagger-${stagger}`]}>
  <div class="project-card__img" aria-hidden="true">
    <span class="project-card__initials">{title.substring(0, 2).toUpperCase()}</span>
  </div>
  <div class="project-card__body">
    <p class="project-card__sector">{secteur}</p>
    <h3 class="project-card__title">{title}</h3>
    <p class="project-card__desc">{description}</p>
    <div class="project-card__stack">
      {stack.map((s) => <Badge label={s} />)}
    </div>
    {!draft && (
      <a
        href={`/realisations/${slug}`}
        class="project-card__link"
        aria-label={`Voir l'étude de cas — ${title}`}
      >
        Voir l'étude de cas <span aria-hidden="true">→</span>
      </a>
    )}
  </div>
</article>

<style>
  .project-card {
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    overflow: hidden;
    transition: transform var(--transition), border-color var(--transition);
    display: flex;
    flex-direction: column;
  }

  .project-card:hover {
    transform: translateY(-4px);
    border-color: var(--accent);
  }

  .project-card__img {
    height: 220px;
    background: linear-gradient(135deg, var(--bg-alt) 0%, var(--border) 100%);
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .project-card__initials {
    font-family: var(--font-display);
    font-size: 4rem;
    font-weight: 300;
    color: var(--border);
    letter-spacing: 0.05em;
  }

  .project-card__body {
    padding: 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    flex: 1;
  }

  .project-card__sector {
    font-size: 0.75rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--accent);
    font-family: var(--font-body);
    font-weight: 500;
    max-width: none;
  }

  .project-card__title {
    font-size: 1.25rem;
    margin: 0;
    line-height: 1.2;
  }

  .project-card__desc {
    color: var(--text-muted);
    font-size: 0.9375rem;
    line-height: 1.6;
    max-width: none;
  }

  .project-card__stack {
    display: flex;
    gap: 0.4rem;
    flex-wrap: wrap;
    margin-top: auto;
  }

  .project-card__link {
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--accent);
    display: inline-flex;
    align-items: center;
    gap: 0.3em;
    transition: gap var(--transition);
    padding-top: 0.5rem;
    border-top: 1px solid var(--border);
    margin-top: 0.5rem;
  }

  .project-card:hover .project-card__link {
    gap: 0.6em;
  }
</style>
