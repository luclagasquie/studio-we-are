---
export interface Props {
  label: string;
  variant?: "default" | "collaborateur";
}

const { label, variant = "default" } = Astro.props;

const displayLabel = variant === "collaborateur"
  ? `Collaboration / ${label}`
  : label;
---
<span class:list={["badge", variant === "collaborateur" && "badge--collab"]}>{displayLabel}</span>

<style>
  .badge {
    display: inline-block;
    padding: 0.2em 0.75em;
    font-size: 0.75rem;
    font-weight: 500;
    letter-spacing: 0.05em;
    border: 1px solid var(--border);
    border-radius: 999px;
    color: var(--text-muted);
    font-family: var(--font-body);
  }

  .badge.badge--collab {
  }
</style>
