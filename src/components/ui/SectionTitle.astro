---
export interface Props {
  label?: string;
  labelTag?: 'p' | 'h1';
  title: string;
  subtitle?: string;
  align?: 'left' | 'center';
}

const { label, labelTag = 'p', title, subtitle, align = 'left' } = Astro.props;
const LabelTag = labelTag;
---
<div class:list={['section-title', align === 'center' && 'section-title--center']}>
  {label && <LabelTag class="section-title__label">{label}</LabelTag>}
  <h2 class="section-title__heading">{title}</h2>
  {subtitle && <p class="section-title__sub" set:html={subtitle} />}
</div>

<style>
  .section-title {
    margin-bottom: 3rem;
  }

  .section-title--center {
    text-align: center;
  }

  .section-title--center .section-title__sub {
    margin-inline: auto;
  }

  .section-title__label {
    font-size: var(--text-s);
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: 1rem;
    font-family: var(--font-body);
    font-weight: 500;
    max-width: none;
  }

  .section-title__heading {
    margin-bottom: 0;
    max-width: 20ch;
    line-height: 1;
    font-size: var(--heading-xl);
  }

  .section-title__sub {
    margin-top: 1.25rem;
    color: var(--text-muted);
    font-size: var(--text-l);
    font-family: var(--font-display);
    font-weight: 300;
    max-width: 70ch;
  }
</style>
