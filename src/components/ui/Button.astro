---
export interface Props {
  href?: string;
  variant?: 'primary' | 'outline' | 'ghost' | 'link';
  size?: 'sm' | 'md' | 'lg';
  type?: 'button' | 'submit';
  class?: string;
}

const {
  href,
  variant = 'primary',
  size = 'md',
  type = 'button',
  class: className = '',
} = Astro.props;

const Tag = href ? 'a' : 'button';
---
<Tag
  href={href}
  type={!href ? type : undefined}
  class:list={['btn', `btn--${variant}`, `btn--${size}`, className]}
>
  <slot />
</Tag>

<style>
  .btn {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-family: var(--font-body);
    font-weight: 500;
    letter-spacing: 0.02em;
    border-radius: var(--radius-sm);
    transition: background var(--transition), color var(--transition),
      border-color var(--transition), transform var(--transition);
    text-decoration: none;
    white-space: nowrap;
    cursor: pointer;
  }

  .btn:active {
    transform: translateY(1px);
  }

  /* Sizes */
  .btn--sm {
    padding: clamp(0.375rem, 1vw, 0.4rem) clamp(0.875rem, 2.5vw, 1rem);
    font-size: clamp(0.8125rem, 1.5vw, 0.875rem);
  }

  .btn--md {
    padding: clamp(0.5rem, 1.5vw, 0.25rem) clamp(1.25rem, 4vw, 1.25rem);
    font-size: clamp(0.875rem, 2vw, 1rem);
  }

  .btn--lg {
    padding: clamp(0.625rem, 2vw, 0.875rem) clamp(1.5rem, 5vw, 2.25rem);
    font-size: clamp(0.9375rem, 2.5vw, 1.0625rem);
  }

  /* Variants */
  .btn--primary {
    background: var(--accent);
    color: #fff;
    border: 1px solid transparent;
  }

  .btn--primary:hover {
    background: var(--accent-light);
  }

  .btn--outline {
    background: transparent;
    color: inherit;
    border: 1px solid currentColor;
  }

  .btn--outline:hover {
    background: var(--accent);
    color: #fff;
    border-color: var(--accent);
  }

  .btn--ghost {
    background: transparent;
    color: var(--accent);
    border: 1px solid transparent;
    padding-inline: 0.25rem;
  }

  .btn--ghost:hover {
    text-decoration: underline;
  }

  .btn--link {
    background: transparent;
    color: inherit;
    border: none;
    padding: 0;
    text-decoration: underline;
    text-decoration-thickness: 1px;
    text-underline-offset: 0.3em;
    font-weight: 400;
    letter-spacing: 0.04em;
    opacity: 0.7;
    transition: opacity var(--transition);
  }

  .btn--link:hover {
    opacity: 1;
  }

  .btn--link:active {
    transform: none;
  }
</style>
