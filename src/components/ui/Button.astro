---
export interface Props {
  href?: string;
  variant?: 'primary' | 'outline' | 'ghost' | 'link';
  size?: 'sm' | 'md' | 'lg';
  type?: 'button' | 'submit';
  class?: string;
}

const {
  href,
  variant = 'primary',
  size = 'md',
  type = 'button',
  class: className = '',
} = Astro.props;

const Tag = href ? 'a' : 'button';
---
<Tag
  href={href}
  type={!href ? type : undefined}
  class:list={['btn', `btn--${variant}`, `btn--${size}`, className]}
>
  <slot />
</Tag>

<style>
  .btn {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-family: var(--font-body);
    font-weight: 500;
    letter-spacing: 0.02em;
    border-radius: var(--radius-sm);
    transition: background var(--transition), color var(--transition),
      border-color var(--transition), transform var(--transition);
    text-decoration: none;
    white-space: nowrap;
    cursor: pointer;
    width: fit-content;
  }

  .btn:active {
    transform: translateY(1px);
  }

  /* Sizes */
  .btn--sm {
    padding: clamp(0.375rem, 1vw, 0.4rem) clamp(0.875rem, 2.5vw, 1rem);
    font-size: clamp(0.8125rem, 1.5vw, 0.875rem);
  }

  .btn--md {
    padding: clamp(0.5rem, 1.5vw, 0.25rem) clamp(1.25rem, 4vw, 1.25rem);
    font-size: clamp(0.875rem, 2vw, 1rem);
  }

  .btn--lg {
    padding: clamp(0.625rem, 2vw, 0.875rem) clamp(1.5rem, 5vw, 2.25rem);
    font-size: clamp(0.9375rem, 2.5vw, 1.0625rem);
  }

  /* Variants */
  .btn--primary {
    position: relative;
    overflow: hidden;
    background: linear-gradient(
      135deg,
      color-mix(in srgb, var(--accent) 80%, transparent),
      color-mix(in srgb, var(--accent) 50%, transparent)
    );
    color: #fff;
    box-shadow:
      0 2px 12px color-mix(in srgb, var(--accent) 25%, transparent),
      inset 0 1px 0 color-mix(in srgb, #fff 20%, transparent);
    backdrop-filter: blur(16px) saturate(1.2);
    -webkit-backdrop-filter: blur(16px) saturate(1.2);
    transition:
      border-color 0.4s ease,
      box-shadow 0.4s ease;
  }

  .btn--primary::before {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(
      135deg,
      color-mix(in srgb, var(--accent) 65%, transparent),
      color-mix(in srgb, var(--accent) 35%, transparent)
    );
    opacity: 0;
    transition: opacity 0.5s ease;
    pointer-events: none;
    z-index: -1;
  }

  .btn--primary:hover {
    box-shadow:
      0 4px 20px color-mix(in srgb, var(--accent) 35%, transparent),
      inset 0 1px 0 color-mix(in srgb, #fff 30%, transparent);
  }

  .btn--primary:hover::before {
    opacity: 0.5;
  }

  .btn--outline {
    background: transparent;
    color: var(--accent);
    border: 1px solid var(--accent);
    /*backdrop-filter: blur(16px) saturate(1.2);
    -webkit-backdrop-filter: blur(16px) saturate(1.2);*/
    transition:
      background 0.4s ease,
      border-color 0.4s ease,
      box-shadow 0.4s ease;
  }

  .btn--outline:hover {
    background: color-mix(in srgb, var(--accent) 15%, transparent);
    border-color: color-mix(in srgb, var(--accent) 80%, transparent);
    box-shadow: 0 2px 8px color-mix(in srgb, var(--accent) 30%, transparent);
  }

  .btn--outline:active {
    background: color-mix(in srgb, var(--accent) 22%, transparent);
    box-shadow: 0 1px 4px color-mix(in srgb, var(--accent) 25%, transparent);
  }

  .btn--ghost {
    background: transparent;
    color: var(--accent);
    border: 1px solid transparent;
    padding-inline: 0.25rem;
  }

  .btn--ghost:hover {
    text-decoration: underline;
  }

  .btn--link {
    background: transparent;
    color: inherit;
    border: none;
    padding: 0;
    text-decoration: underline;
    text-decoration-thickness: 1px;
    text-underline-offset: 0.3em;
    font-weight: 400;
    letter-spacing: 0.04em;
    opacity: 0.7;
    transition: opacity var(--transition);
  }

  .btn--link:hover {
    opacity: 1;
  }

  .btn--link:active {
    transform: none;
  }
</style>
