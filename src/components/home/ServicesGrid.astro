---
import SectionTitle from '../ui/SectionTitle.astro';
import ServiceCard from './ServiceCard.astro';
import servicesData from '../../data/services.json';
import type { ImageMetadata } from 'astro';

const serviceImages = import.meta.glob<{ default: ImageMetadata }>(
  '../../assets/services/*.{jpg,jpeg,png,webp,avif}',
  { eager: true }
);

function getServiceImage(filename: string): ImageMetadata {
  const key = Object.keys(serviceImages).find(k => k.endsWith('/' + filename));
  if (!key) throw new Error(`Service image not found: ${filename}`);
  return serviceImages[key].default;
}

type Service = {
  id: string;
  title: string;
  tagline: string;
  icon: string;
  image: string;
};

const services = servicesData as Service[];
---
<section class="services-section" id="prestations">
  <div class="container">
    <div class="services-header animate-fade">
      <SectionTitle
        label="Ce que je fais"
        title="Des compétences au service de votre projet"
      />
      <p class="services-header__note">
        Du site vitrine au e-commerce complexe — je choisis
        la solution la plus adaptée, pas la plus impressionnante.
      </p>
    </div>
    <div class="services-grid">
      {services.map((s, i) => (
        <ServiceCard
          id={s.id}
          title={s.title}
          tagline={s.tagline}
          icon={s.icon}
          image={getServiceImage(s.image)}
          stagger={Math.min(i + 1, 6)}
          index={i + 1}
        />
      ))}
    </div>
    <div class="services-foot animate-fade stagger-3">
      <a href="/prestations" class="services-foot__link">
        Découvrez mes prestations <span aria-hidden="true">→</span>
      </a>
    </div>
  </div>
</section>

<style>
  .services-section {
    padding-block: var(--space-xl);
    border-top: 1px solid var(--border);
    background-color: var(--bg);
  }

  .services-header {
    display: grid;
    grid-template-columns: 1fr minmax(0, 400px);
    align-items: end;
    gap: 4rem;
    margin-bottom: 0;
  }

  .services-header :global(.section-title) {
    margin-bottom: 0;
  }

  .services-header__note {
    font-size: var(--text-m);
    color: var(--text-muted);
    line-height: 1.7;
    text-align: right;
    overflow-wrap: break-word;
    padding-bottom: 0.25rem;
  }

  .services-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2rem;
    margin-top: 4rem;
  }

  @media (max-width: 900px) {
    .services-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 560px) {
    .services-grid {
      grid-template-columns: 1fr;
    }
  }

  .services-foot {
    margin-top: 4rem;
    display: flex;
    justify-content: center;
  }

  .services-foot__link {
    font-size: var(--text-s);
    font-weight: 500;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--text);
    display: inline-flex;
    align-items: center;
    gap: 0.75em;
    border-bottom: 1px solid var(--border);
    padding-bottom: 0.3em;
    text-decoration: none;
    transition: border-color var(--transition), color var(--transition);
  }

  .services-foot__link:hover {
    color: var(--accent);
    border-color: var(--accent);
  }

  @media (max-width: 640px) {
    .services-header {
      grid-template-columns: 1fr;
      gap: 1rem;
    }

    .services-header__note {
      text-align: left;
      max-width: none;
    }

    .services-foot {
      justify-content: flex-start;
    }
  }
</style>
