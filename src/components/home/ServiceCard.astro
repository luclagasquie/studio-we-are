---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';

export interface Props {
  id: string;
  title: string;
  tagline: string;
  icon: string;
  image: ImageMetadata;
  stagger?: number;
  index?: number;
}

const { id, title, tagline, image, stagger = 0, index = 0 } = Astro.props;
---

<div
  class:list={['service-card', 'animate-slide', stagger > 0 && `stagger-${stagger}`]}
  data-service-card
>
  <div class:list={['service-card__bg', 'image-shimmer']}>
    <Image
      src={image}
      alt=""
      width={560}
      height={646}
      densities={[1, 2]}
      sizes="(max-width: 560px) 100vw, (max-width: 900px) 50vw, 33vw"
      class="service-card__image"
      loading={index <= 2 ? 'eager' : 'lazy'}
      {...(index <= 2 ? { fetchpriority: 'high' } : {})}
    />
    <div class="service-card__overlay" aria-hidden="true"></div>
  </div>
  <div class="service-card__body">
    <h3 style="white-space: pre-line" class="service-card__title">{title}</h3>
    <p class="service-card__desc">{tagline}</p>
  </div>
</div>

<style>
  .service-card {
    position: relative;
    min-height: 320px;
    aspect-ratio: 2 / 2.3;
    background: transparent;
    border-radius: var(--radius-m);
    overflow: hidden;
    color: inherit;
    display: flex;
    align-items: flex-end;
  }

  /* ── Background image ── */
  .service-card__bg {
    position: absolute;
    inset: 0;
    z-index: 0;
  }

  .service-card__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    opacity: 0;
    transition: opacity 0.4s ease, transform 0.5s ease-out;
  }

  .is-loaded .service-card__image {
    opacity: 1;
  }

  .service-card:hover .service-card__image {
    transform: scale(1.05);
  }

  /* ── Overlay ── */
  .service-card__overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to bottom,
      rgba(0, 0, 0, 0) 0%,
      rgba(0, 0, 0, 0.25) 60%,
      rgba(0, 0, 0, 0.75) 100%
    );
  }

  .service-card__overlay::after {
    content: '';
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, 0.10);
    opacity: 0;
    transition: opacity 0.5s ease-out;
  }

  .service-card:hover .service-card__overlay::after {
    opacity: 1;
  }

  /* ── Body ── */
  .service-card__body {
    position: relative;
    z-index: 1;
    flex: 1;
    padding: 2rem 1.75rem;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .service-card__title {
    font-family: var(--font-display);
    font-size: var(--heading-m);
    font-weight: 400;
    line-height: 1.2;
    letter-spacing: -0.01em;
    color: #ffffff;
  }

  .service-card__desc {
    font-size: var(--text-m);
    line-height: 1.7;
    color: rgba(255, 255, 255, 0.9);
  }

  @media (prefers-reduced-motion: reduce) {
    .service-card__overlay::after {
      transition: none;
    }
    .service-card__image {
      transition: none;
    }
    .service-card:hover .service-card__image {
      transform: none;
    }
  }
</style>
