---
export interface Props {
  title: string;
  tagline: string;
  icon: string;
  href?: string;
  stagger?: number;
}

const { title, tagline, icon, href = '/services', stagger = 0 } = Astro.props;

// Simple icon map — inline SVG paths (Lucide-style)
const icons: Record<string, string> = {
  monitor: 'M20 3H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2V5a2 2 0 0 0-2-2zM2 9h20',
  'shopping-bag': 'M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4zM3 6h18M16 10a4 4 0 0 1-8 0',
  layout: 'M12 3H3a1 1 0 0 0-1 1v7a1 1 0 0 0 1 1h9m0-9h9a1 1 0 0 1 1 1v7a1 1 0 0 1-1 1h-9m0-9v9m0 0v9m0 0H3a1 1 0 0 1-1-1v-7a1 1 0 0 1 1-1h9m9 0h-9',
  zap: 'M13 2 3 14h9l-1 8 10-12h-9l1-8z',
  shield: 'M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z',
  'message-circle': 'M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z',
  camera: 'M23 19a2 2 0 0 1-2 2H3a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h4l2-3h6l2 3h4a2 2 0 0 1 2 2zM12 17a4 4 0 1 0 0-8 4 4 0 0 0 0 8z',
};

const iconPath = icons[icon] ?? icons['monitor'];
---
<article class:list={['service-card', 'animate-slide', stagger > 0 && `stagger-${stagger}`]}>
  <div class="service-card__icon" aria-hidden="true">
    <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor"
         stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
      <path d={iconPath} />
    </svg>
  </div>
  <h3 class="service-card__title">{title}</h3>
  <p class="service-card__tagline">{tagline}</p>
  <a href={href} class="service-card__link" aria-label={`En savoir plus sur ${title}`}>
    En savoir plus <span aria-hidden="true">→</span>
  </a>
</article>

<style>
  .service-card {
    background: var(--bg);
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    padding: 2rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
    transition: border-color var(--transition), transform var(--transition);
  }

  .service-card:hover {
    border-color: var(--accent);
    transform: translateY(-3px);
  }

  .service-card__icon {
    width: 3rem;
    height: 3rem;
    background: var(--bg-alt);
    border-radius: var(--radius-sm);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--accent);
    flex-shrink: 0;
  }

  .service-card__title {
    font-size: 1.3rem;
    margin: 0;
  }

  .service-card__tagline {
    color: var(--text-muted);
    font-size: 0.9375rem;
    flex: 1;
    line-height: 1.6;
    max-width: none;
  }

  .service-card__link {
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--accent);
    display: inline-flex;
    align-items: center;
    gap: 0.3em;
    transition: gap var(--transition);
    margin-top: auto;
  }

  .service-card:hover .service-card__link {
    gap: 0.6em;
  }
</style>
