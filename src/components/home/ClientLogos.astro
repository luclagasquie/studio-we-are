---
import { clientLogos } from '../../data/clientLogos';

const ASSUMED_ITEM_PX = 320;
const estimatedGroupWidth = clientLogos.length * ASSUMED_ITEM_PX;
const repeatCount = Math.max(4, Math.ceil(1920 / estimatedGroupWidth) + 1);
const marqueeDuration = `${Math.max(40, clientLogos.length * 10)}s`;
const initialShift = `-${estimatedGroupWidth}px`;
---

{clientLogos.length > 0 && (
  <section
    class="client-logos"
    style={`--logos-duration: ${marqueeDuration}; --marquee-shift: ${initialShift};`}
  >
    <div class="logos-outer" aria-hidden="true">
      <div class="logos-track">
        {Array.from({ length: repeatCount }, (_, i) => (
          <ul class="logos-group" role="list" aria-hidden={i > 0 ? "true" : undefined}>
            {clientLogos.map((logo) => (
              <li class="logos-item">
                <div class="logos-logo">
                  <img
                    src={logo.src}
                    alt={logo.alt}
                    class="logos-logo__img"
                    loading="lazy"
                    decoding="async"
                    width="160"
                    height="80"
                  />
                </div>
              </li>
            ))}
          </ul>
        ))}
      </div>
    </div>
  </section>
)}

<script>
  function initMarquee() {
    const section = document.querySelector<HTMLElement>('.client-logos');
    const firstGroup = section?.querySelector<HTMLElement>('.logos-group');
    if (!section || !firstGroup) return;
    section.style.setProperty('--marquee-shift', `-${firstGroup.offsetWidth}px`);
  }

  initMarquee();
  document.addEventListener('astro:page-load', initMarquee);
</script>

<style>
  .client-logos {
    background-color: var(--bg-alt);
    padding-block: var(--space-xl);
    border-top: 1px solid var(--border);
    border-bottom: 1px solid var(--border);
    overflow: hidden;
  }

  .logos-outer {
    position: relative;
    overflow: hidden;
    mask-image: linear-gradient(
      to right,
      transparent 0%,
      black 10%,
      black 90%,
      transparent 100%
    );
    -webkit-mask-image: linear-gradient(
      to right,
      transparent 0%,
      black 10%,
      black 90%,
      transparent 100%
    );
  }

  .logos-track {
    display: flex;
    width: max-content;
    animation: marquee-logos var(--logos-duration) linear infinite;
    will-change: transform;
  }

  .logos-group {
    display: flex;
    align-items: center;
    flex-shrink: 0;
  }

  .logos-item {
    display: flex;
    align-items: center;
    padding-inline: clamp(2.5rem, 8vw, 5rem);
    position: relative;
  }

  .logos-item:after {
    content: "";
    position: absolute;
    right: 0;
    top: 50%;
    transform: translateY(-50%);
    width: 3px;
    height: 3px;
    border-radius: 50%;
    background: var(--border);
    opacity: 0.8;
  }

  .logos-logo {
    display: flex;
    align-items: center;
    filter: grayscale(100%);
    opacity: 0.3;
    transition: filter var(--transition), opacity var(--transition);
  }

  .logos-logo:hover {
    filter: grayscale(0%);
  }

  .logos-logo__img {
    display: block;
    height: 80px;
    width: auto;
    max-width: 160px;
  }

  :global([data-theme='dark']) .logos-logo {
    filter: grayscale(100%) invert(1);
    opacity: 0.6;
  }

  :global([data-theme='dark']) .logos-logo:hover {
    filter: grayscale(0%) invert(1);
  }

  @media (prefers-reduced-motion: reduce) {
    .logos-track {
      animation: none !important;
      width: 100%;
      flex-wrap: wrap;
      justify-content: center;
      gap: 1rem 3rem;
    }

    .logos-group[aria-hidden='true'] {
      display: none;
    }

    .logos-outer {
      mask-image: none;
      -webkit-mask-image: none;
    }
  }
</style>
