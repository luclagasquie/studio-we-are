---
import { Image } from 'astro:assets';
import Button from '../ui/Button.astro';
import heroBg from '../../assets/hero/luc-lagasquie-paysage-lot.webp';
---
<section class="hero" aria-label="Section principale">
  <div class="hero__bg" role="presentation">
    <Image
      src={heroBg}
      alt="Paysage du Lot — brume sur la forêt au lever du soleil"
      class="hero__img"
      loading="eager"
      fetchpriority="high"
      widths={[640, 1024, 1440, 1920]}
      sizes="100vw"
    />
  </div>

  <!-- Ligne verticale décorative -->
  <div class="hero__rule-v" aria-hidden="true"></div>

  <div class="hero__content container">
    <div class="hero__header hero-animate">
      <span class="hero__eyebrow">Studio We Are</span>
      <span class="hero__year">Est. 2009</span>
    </div>

    <h1 class="hero__title hero-animate">
      Des sites qui<br />
      travaillent<br />
      <em>pour vous</em>
    </h1>

    <div class="hero__foot hero-animate">
      <p class="hero__subtitle">
        Développement web sur-mesure,<br />
        conseil stratégique &amp; accompagnement.
      </p>
      <div class="hero__actions">
        <Button href="#prestations" variant="primary" size="md">Mes prestations</Button>
        <Button href="/contact/" variant="link">Prendre contact</Button>
      </div>
    </div>
  </div>

  <!-- Indicateur de scroll -->
  <div class="hero__scroll-line" aria-hidden="true">
    <span class="hero__scroll-label">Défiler</span>
    <div class="hero__scroll-bar"></div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    min-height: 100dvh;
    display: flex;
    flex-direction: column;
    justify-content: center;
    overflow: hidden;
    /* Isolate this section's stacking context so its z-index children
       (hero__content, hero__rule-v, etc.) don't interfere with the fixed header */
    isolation: isolate;
  }

  .hero__bg {
    position: absolute;
    inset: 0;
    overflow: hidden;
    background-color: #130E0A;
  }

  .hero__bg::after {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(
      170deg,
      rgba(10, 8, 5, 0.15) 0%,
      rgba(10, 8, 5, 0.45) 50%,
      rgba(10, 8, 5, 0.88) 100%
    );
  }

  .hero__img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center top;
    opacity: 0;
    transition: opacity 0.7s ease-out;
  }

  .hero__img.is-loaded {
    opacity: 1;
  }

  @media (prefers-reduced-motion: reduce) {
    .hero__img {
      transition: none;
      opacity: 1;
    }
  }

  /* Ligne verticale décorative à droite */
  .hero__rule-v {
    position: absolute;
    top: var(--space-xl);
    right: var(--gutter);
    width: 1px;
    height: clamp(60px, 10vw, 120px);
    background: rgba(240, 237, 232, 0.3);
    z-index: 1;
  }

  .hero__content {
    position: relative;
    z-index: 1;
    color: #f0ede8;
    /* Add header height (4.5rem) on top of the section's natural spacing */
    padding-top: calc(clamp(4rem, 9vw, 9rem) - 4.5rem);
    padding-bottom: clamp(4rem, 9vw, 9rem);
    display: flex;
    flex-direction: column;
    gap: clamp(2.5rem, 5vw, 8rem);
  }

  /* Ligne de header : studio + année */
  .hero__header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding-top: 4rem;
  }

  .hero__eyebrow {
    font-size: 0.75rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    font-family: var(--font-body);
    font-weight: 500;
    color: rgba(240, 237, 232, 0.75);
  }

  .hero__year {
    font-size: 0.75rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    font-family: var(--font-body);
    color: rgba(240, 237, 232, 0.75);
  }

  /* Titre principal */
  .hero__title {
    font-size: clamp(3.5rem, 10vw, 7rem);
    color: #f0ede8;
    line-height: 0.9;
    letter-spacing: -0.04em;
    font-weight: 300;
    max-width: 12ch;
  }

  .hero__title em {
    font-style: italic;
    color: #d4a882;
    font-weight: 300;
  }

  /* Pied de hero : sous-titre + CTAs */
  .hero__foot {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 3rem;
    flex-wrap: wrap;
  }

  .hero__subtitle {
    font-size: var(--text-m);
    color: rgba(240, 237, 232, 0.75);
    font-weight: 300;
    line-height: 1.9;
    max-width: 36ch;
    letter-spacing: 0.01em;
  }

  .hero__actions {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    flex-shrink: 0;
    flex-wrap: wrap;
  }

  /* Indicateur de scroll */
  .hero__scroll-line {
    position: absolute;
    bottom: clamp(2rem, 4vw, 3.5rem);
    left: var(--gutter);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.75rem;
    z-index: 1;
    color: rgba(240, 237, 232, 0.75);
  }

  .hero__scroll-label {
    font-size: 0.6875rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    font-family: var(--font-body);
    writing-mode: vertical-rl;
    transform: rotate(180deg);
  }

  .hero__scroll-bar {
    width: 1px;
    height: 48px;
    background: rgba(240, 237, 232, 0.25);
    position: relative;
    overflow: hidden;
  }

  .hero__scroll-bar::after {
    content: '';
    position: absolute;
    top: -100%;
    left: 0;
    width: 100%;
    height: 100%;
    background: rgba(240, 237, 232, 0.7);
    animation: scrollLine 2s ease-in-out infinite;
  }

  @keyframes scrollLine {
    0% { top: -100%; }
    100% { top: 100%; }
  }

  @media (prefers-reduced-motion: reduce) {
    .hero__scroll-bar::after {
      animation: none;
      top: 0;
    }
  }

  @media (max-width: 640px) {

    .hero {
      min-height: auto;
    }

    .hero__foot {
      flex-direction: column;
      align-items: flex-start;
      gap: 1.5rem;
    }

    .hero__eyebrow {
      display: none;
    }

    .hero__rule-v {
      display: none;
    }

    /* Reserve space for the "Défiler" scroll indicator (~170px from bottom) */
    .hero__content {
      padding-bottom: 11rem;
      padding-block-start: 4rem;
    }
  }
</style>

<script>
  function initHeroImage() {
    const img = document.querySelector<HTMLImageElement>('.hero__img');
    if (!img) return;
    if (img.complete) {
      img.classList.add('is-loaded');
    } else {
      img.addEventListener('load', () => img.classList.add('is-loaded'));
    }
  }

  initHeroImage();
  document.addEventListener('astro:page-load', initHeroImage);
</script>
