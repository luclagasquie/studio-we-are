---
import { Image } from 'astro:assets';
import PageLayout from '../layouts/PageLayout.astro';
import SectionTitle from '../components/ui/SectionTitle.astro';
import CtaSection from '../components/home/CtaSection.astro';
import heroBg from '../assets/sections/luc-lagasquie-portfolio-95.jpg';
---
<PageLayout
  title="Services — Studio We Are"
  description="Création de sites web vitrine, e-commerce, WordPress sur-mesure, Astro. Conseil, maintenance, photographie. Lot, France."
>
  <!-- Page hero -->
  <section class="page-hero" aria-label="Services">
    <div class="page-hero__bg" role="presentation">
      <Image
        src={heroBg}
        alt="Paysage du Lot — brume sur la forêt au lever du soleil"
        class="page-hero__img"
        loading="eager"
        fetchpriority="high"
        widths={[640, 1024, 1440, 1920]}
        sizes="100vw"
      />
    </div>
    <div class="page-hero__content container">
      <span class="page-hero__label">Prestations</span>
      <h1 class="page-hero__title">
        Un site web taillé<br />
        <em>pour votre projet</em>
      </h1>
      <div class="page-hero__rule" aria-hidden="true"></div>
    </div>
  </section>

  <!-- Two families -->
  <section class="section">
    <div class="container">
      <SectionTitle label="01." title="L'approche" />
      <div class="families">
        <div class="family animate-slide stagger-1">
          <div class="family__tag-wrap">
            <span class="family__badge">Rapide à déployer</span>
            <span class="family__budget">À partir de 800 €</span>
          </div>
          <h2 class="family__title">Sites rapides à mettre en place</h2>
          <p class="family__intro">
            Pour les besoins urgents, les budgets maîtrisés ou les projets simples.
            On part de bases éprouvées, on personnalise l'essentiel.
          </p>
          <ul class="family__list">
            <li>Hébergement gratuit possible (Cloudflare Pages, etc.)</li>
            <li>Livraison en quelques semaines</li>
            <li>Contenu modifiable sur demande</li>
            <li>Idéal : auto-entrepreneurs, artisans, associations, artistes</li>
          </ul>
        </div>

        <div class="family family--accent animate-slide stagger-2">
          <div class="family__tag-wrap">
            <span class="family__badge">Sur-mesure</span>
            <span class="family__budget">À partir de 2 000 €</span>
          </div>
          <h2 class="family__title">Sites réalisés de A à Z</h2>
          <p class="family__intro">
            Pour les projets ambitieux, durables, entièrement personnalisés.
            Développement complet, choix libres, durée de vie longue.
          </p>
          <ul class="family__list">
            <li>Développement entièrement sur-mesure</li>
            <li>Avec ou sans interface d'édition de contenu</li>
            <li>Liberté totale sur le choix d'hébergeur</li>
            <li>Idéal : PME, e-commerce, secteur public, projets à fort trafic</li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- Tech table -->
  <section class="section section--alt">
    <div class="container">
      <SectionTitle label="02." title="La technique" />
      <div class="table-wrap animate-fade">
        <table class="tech-table">
          <thead>
            <tr>
              <th class="th-num" scope="col" aria-label="Numéro"></th>
              <th scope="col">Offre</th>
              <th scope="col">Stack technique</th>
              <th scope="col">Idéal pour</th>
            </tr>
          </thead>
          <tbody>
            <tr>
              <td class="td-num" aria-hidden="true">01</td>
              <td class="td-offer">WordPress classique</td>
              <td class="td-stack">
                <span class="stack-tag">Bricks</span>
                <span class="stack-tag">Etch</span>
                <span class="stack-tag">Plugins</span>
              </td>
              <td class="td-ideal">Clients souhaitant gérer leur contenu</td>
            </tr>
            <tr>
              <td class="td-num" aria-hidden="true">02</td>
              <td class="td-offer">WordPress headless</td>
              <td class="td-stack">
                <span class="stack-tag">Astro</span>
                <span class="stack-tag">HTML</span>
                <span class="stack-tag">CSS</span>
                <span class="stack-tag">JS</span>
              </td>
              <td class="td-ideal">Performance maximale + gestion de contenu</td>
            </tr>
            <tr>
              <td class="td-num" aria-hidden="true">03</td>
              <td class="td-offer">Astro statique</td>
              <td class="td-stack">
                <span class="stack-tag">Markdown</span>
                <span class="stack-tag">HTML</span>
                <span class="stack-tag">CSS</span>
                <span class="stack-tag">JS</span>
              </td>
              <td class="td-ideal">Sites rapides sans back-office</td>
            </tr>
            <tr>
              <td class="td-num" aria-hidden="true">04</td>
              <td class="td-offer">WooCommerce</td>
              <td class="td-stack">
                <span class="stack-tag">Bricks</span>
                <span class="stack-tag">WooCommerce</span>
                <span class="stack-tag">Plugins</span>
              </td>
              <td class="td-ideal">E-commerce avec besoins spécifiques</td>
            </tr>
            <tr>
              <td class="td-num" aria-hidden="true">05</td>
              <td class="td-offer">Shopify<sup class="td-offer__note">*</sup></td>
              <td class="td-stack">
                <span class="stack-tag">Thème premium adapté</span>
              </td>
              <td class="td-ideal">E-commerce clé en main</td>
            </tr>
          </tbody>
        </table>
      </div>
      <p class="table-footnote">
        <span class="table-footnote__mark">*</span>
        Shopify est une solution commerciale par abonnement que je réserve aux petites structures soucieuses de leur budget et prêtes à accepter les contraintes d'un système fermé.
      </p>
    </div>
  </section>

  <!-- Encarts -->
  <section class="section">
    <div class="container">
      <SectionTitle label="03." title="Les services" />
      <div class="encarts">
        <div class="encart animate-slide stagger-1">
          <div class="encart__top">
            <div class="encart__icon" aria-hidden="true">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/>
              </svg>
            </div>
          </div>
          <h3>Accompagnement</h3>
          <p>
            Pas juste une livraison de fichiers. Je prends le temps de comprendre votre activité et vos objectifs — pour vous conseiller des solutions qui correspondent vraiment à votre situation. Du premier échange à la mise en ligne, vous savez à qui vous parlez.
          </p>
        </div>

        <div class="encart animate-slide stagger-2">
          <div class="encart__top">
            <div class="encart__icon" aria-hidden="true">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M22 12h-4l-3 9L9 3l-3 9H2"/>
              </svg>
            </div>
          </div>
          <h3>Marketing et référencement</h3>
          <p>
            Un beau site ne sert à rien s'il reste invisible. Je travaille le
            référencement naturel dès la construction : structure, performance,
            mots-clés, balisage sémantique. Pour que votre site génère des visites
            et des contacts, pas seulement de l'admiration.
          </p>
        </div>

        <div class="encart animate-slide stagger-3">
          <div class="encart__top">
            <div class="encart__icon" aria-hidden="true">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <rect x="3" y="11" width="18" height="11" rx="2" ry="2"/>
                <path d="M7 11V7a5 5 0 0 1 10 0v4"/>
                <line x1="12" y1="16" x2="12" y2="16"/>
              </svg>
            </div>
          </div>
          <h3>Confidentialité et RGPD</h3>
          <p>
            Formulaires, cookies, données personnelles : la réglementation européenne s'applique à tous les sites. J'intègre les bonnes pratiques en privilégiant une approche sans cookies — pour que votre site soit conforme sans que ce soit votre problème.
          </p>
        </div>

        

        <div class="encart animate-slide stagger-4">
          <div class="encart__top">
            <div class="encart__icon" aria-hidden="true">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
                <polyline points="9 12 11 14 15 10"/>
              </svg>
            </div>
          </div>
          <h3>Suivi et maintenance</h3>
          <p>
            Un site qui vit, ça s'entretient. Je propose un suivi technique régulier :
            mises à jour, sauvegardes automatisées, surveillance des performances,
            corrections rapides en cas de problème. Vous vous concentrez sur votre activité
            — votre site reste en bon état.
          </p>
        </div>

        <div class="encart animate-slide stagger-5">
          <div class="encart__top">
            <div class="encart__icon" aria-hidden="true">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/>
                <circle cx="12" cy="12" r="3"/>
              </svg>
            </div>
          </div>
          <h3>Accessibilité</h3>
          <p>
            Chaque site est pensé pour être utilisable par tous : contrastes suffisants,
            navigation au clavier, descriptions des images, labels de formulaires,
            structure sémantique correcte. Je veille au respect des normes WCAG 2.1 AA
            — une responsabilité, et un avantage pour le référencement.
          </p>
        </div>

        <div class="encart animate-slide stagger-6">
          <div class="encart__top">
            <div class="encart__icon" aria-hidden="true">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M4 11a9 9 0 0 1 9 9"/>
                <path d="M4 4a16 16 0 0 1 16 16"/>
                <circle cx="5" cy="19" r="1"/>
              </svg>
            </div>
          </div>
          <h3>Veille technologique continue</h3>
          <p>
            Les outils évoluent vite — je les suis activement.
            IA, nouveaux frameworks, automatisations : cette curiosité me permet de
            vous proposer des solutions pertinentes plutôt que des modes passagères.
          </p>
        </div>


        <div class="encart animate-slide stagger-7">
          <div class="encart__top">
            <div class="encart__icon" aria-hidden="true">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/>
                <circle cx="9" cy="7" r="4"/>
                <path d="M23 21v-2a4 4 0 0 0-3-3.87"/>
                <path d="M16 3.13a4 4 0 0 1 0 7.75"/>
              </svg>
            </div>
          </div>
          <h3>Graphisme haut de gamme</h3>
          <p>
            Pour les projets nécessitant une identité visuelle forte, je travaille avec
            Céline Andrieu, graphiste indépendante. Direction artistique, maquettes,
            charte graphique — conçus avec soin et intégrés avec précision dans le code.
          </p>
          <div class="encart__footer">
            <span class="encart__option">Sur demande</span>
            <a href="https://celineandrieu.com/" class="encart__univers" target="_blank" rel="noopener noreferrer">
              Son Univers
              <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>
            </a>
          </div>
        </div>

        <div class="encart animate-slide stagger-8">
          <div class="encart__top">
            <div class="encart__icon" aria-hidden="true">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M23 19a2 2 0 0 1-2 2H3a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h4l2-3h6l2 3h4a2 2 0 0 1 2 2z"/>
                <circle cx="12" cy="13" r="4"/>
              </svg>
            </div>
          </div>
          <h3>Photographie et contenu visuel</h3>
          <p>
            Des photographes professionnels produisent des visuels authentiques et adaptés à votre projet : reportage d'entreprise, portraits, photos de produits ou d'ambiance. Des images pensées pour votre site, vos réseaux et votre communication imprimée.
          </p>
          <span class="encart__option">Sur demande</span>
        </div>

        <div class="encart animate-slide stagger-9">
          <div class="encart__top">
            <div class="encart__icon" aria-hidden="true">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/>
                <path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/>
              </svg>
            </div>
          </div>
          <h3>Rédaction et contenu éditorial</h3>
          <p>
            Des rédacteurs professionnels analysent vos thématiques, structurent vos offres et rédigent des textes optimisés pour le référencement. Des contenus qui convainquent autant qu'ils vous positionnent durablement dans les résultats de recherche.
          </p>
          <span class="encart__option">Sur demande</span>
        </div>
      </div>
    </div>
  </section>

  <CtaSection />
</PageLayout>

<style>
  /* ── Photo hero ── */
  .page-hero {
    position: relative;
    display: flex;
    align-items: center;
    overflow: hidden;
    isolation: isolate;
  }

  .page-hero__bg {
    position: absolute;
    inset: 0;
  }

  .page-hero__bg::after {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(
      170deg,
      rgba(10, 8, 5, 0.15) 0%,
      rgba(10, 8, 5, 0.52) 50%,
      rgba(10, 8, 5, 0.78) 100%
    );
  }

  .page-hero__img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 45%;
  }

  .page-hero__content {
    position: relative;
    z-index: 1;
    color: #f0ede8;
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.25rem;
    /* Header height + generous breathing room above and below */
    padding-block: clamp(2.5rem, 7vw, 7.5rem);
  }

  .page-hero__label {
    font-family: var(--font-body);
    font-size: 0.75rem;
    font-weight: 500;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: rgba(212, 168, 130, 0.9);
  }

  .page-hero__title {
    font-family: var(--font-display);
    font-size: clamp(2.75rem, 7vw, 5.5rem);
    font-weight: 300;
    line-height: 0.9;
    letter-spacing: -0.02em;
    color: #f0ede8;
    max-width: 18ch;
    /* Subtle text-shadow improves contrast on bright photo areas */
    text-shadow: 0 2px 32px rgba(10, 8, 5, 0.45);
  }

  .page-hero__title em {
    font-style: italic;
    color: #d4a882;
    font-weight: 300;
  }

  .page-hero__rule {
    width: 40px;
    height: 1px;
    background: rgba(212, 168, 130, 0.55);
  }

  .page-hero__subtitle {
    font-family: var(--font-body);
    font-size: clamp(0.9rem, 1.4vw, 1.0625rem);
    font-weight: 300;
    color: rgba(240, 237, 232, 0.65);
    letter-spacing: 0.01em;
    line-height: 1.7;
  }

  .families {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 2.5rem;
  }

  .family {
    padding: 2.5rem;
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
  }

  .family--accent {
    border-color: var(--accent);
    background: color-mix(in srgb, var(--accent) 4%, var(--bg));
  }

  .family__tag-wrap {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-bottom: 1.25rem;
  }

  .family__badge {
    font-size: 0.85rem;
    letter-spacing: 0.08em;
    font-weight: 500;
    color: #fff;
    background: var(--accent);
    padding: 0.2em 1em;
    border-radius: 999px;
  }

  .family__budget {
    font-size: 0.85rem;
    letter-spacing: 0.06em;
    font-weight: 500;
    color: var(--accent);
    background: transparent;
    border-bottom: 1px solid var(--accent);
    padding: 0.05em 0em;
  }

  .family__title {
    font-size: var(--heading-l);
    margin-bottom: 1rem;
    line-height: 1.2;
  }

  .family__intro {
    color: var(--text-muted);
    margin-bottom: 1.5rem;
    font-size: var(--text-l);
    max-width: none;
    font-family: var(--font-display);
  }

  .family__list {
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
  }

  .family__list li {
    color: var(--text-muted);
    font-size: var(--text-s);
    display: flex;
    align-items: center;
    gap: 1rem;
  }

  .family__list li::before {
    content: '';
    width: 5px;
    height: 5px;
    flex-shrink: 0;
    background-color: var(--accent);
  }

  /* ── Table footnote ── */
  .table-footnote {
    margin-top: 1.25rem;
    font-size: var(--text-s);
    color: var(--text-muted);
    font-style: italic;
    line-height: 1.6;
    display: flex;
    gap: 0.4em;
    max-width: 80ch;
  }

  .table-footnote__mark {
    font-family: var(--font-display);
    font-size: 1rem;
    color: var(--accent);
    opacity: 0.6;
    flex-shrink: 0;
    line-height: 1.4;
  }

  .td-offer__note {
    font-family: var(--font-display);
    font-size: 0.875em;
    color: var(--accent);
    opacity: 0.7;
    vertical-align: super;
    margin-left: 0.1em;
  }

  /* ── Tech table ── */
  .table-wrap {
    overflow-x: auto;
  }

  .tech-table {
    width: 100%;
    border-collapse: collapse;
    min-width: 620px;
  }

  /* Header */
  .tech-table th {
    font-family: var(--font-body);
    font-weight: 500;
    font-size: 0.6875rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--text-muted);
    background: transparent;
    text-align: left;
    padding: 0.875rem 1.5rem 0.875rem 0;
    border-bottom: 1px solid var(--text-muted);
  }

  .th-num {
    width: 4.5rem;
    padding-right: 0 !important;
  }

  /* Cells */
  .tech-table td {
    padding: 1.875rem 1.5rem 1.875rem 0;
    border-bottom: 1px solid var(--border);
    vertical-align: middle;
  }

  .tech-table tbody tr:last-child td {
    border-bottom: none;
  }

  /* Hover row: warm wash + inset accent line on first cell */
  .tech-table tbody tr {
    transition: background 0.35s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .tech-table tbody tr:hover {
    background: color-mix(in srgb, var(--accent) 4%, var(--bg-alt));
  }

  .tech-table tbody tr:hover .td-num {
    opacity: 0.75;
    box-shadow: inset 1px 0 0 var(--accent);
    padding-left: 0.875rem;
  }

  /* Row number */
  .td-num {
    font-family: var(--font-display);
    font-size: 1.875rem;
    font-weight: 300;
    letter-spacing: -0.03em;
    color: var(--accent);
    opacity: 0.28;
    padding-right: 0.5rem !important;
    padding-left: 0;
    transition:
      opacity 0.35s cubic-bezier(0.4, 0, 0.2, 1),
      box-shadow 0.35s cubic-bezier(0.4, 0, 0.2, 1),
      padding-left 0.35s cubic-bezier(0.4, 0, 0.2, 1);
    width: 4.5rem;
  }

  /* Offer name */
  .td-offer {
    font-family: var(--font-display);
    font-size: 1.375rem;
    font-weight: 400;
    letter-spacing: -0.01em;
    color: var(--text);
    min-width: 14rem;
  }

  /* Stack badges */
  .td-stack {
    min-width: 180px;
  }

  .stack-tag {
    display: inline-block;
    font-family: var(--font-body);
    font-size: 0.6875rem;
    font-weight: 500;
    letter-spacing: 0.05em;
    color: var(--accent);
    background: color-mix(in srgb, var(--accent) 7%, var(--bg));
    border: 1px solid color-mix(in srgb, var(--accent) 22%, var(--border));
    padding: 0.2em 0.65em;
    border-radius: 2px;
    margin-right: 0.3rem;
    margin-bottom: 0.3rem;
    white-space: nowrap;
  }

  /* Ideal for */
  .td-ideal {
    font-family: var(--font-body);
    font-size: var(--text-s);
    font-style: italic;
    color: var(--text-muted);
    min-width: 14rem;
  }

  .encarts {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 2.5rem;
  }

  .encart {
    padding: 2rem;
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    display: flex;
    flex-direction: column;
    gap: 1rem;
    transition:
      border-color var(--transition),
      box-shadow var(--transition);
  }

  .encart:hover {
    border-color: var(--accent);
    box-shadow: 0 8px 32px -8px color-mix(in srgb, var(--accent) 20%, transparent);
  }

  .encart__top {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.75rem;
  }

  .encart__icon {
    width: 3rem;
    height: 3rem;
    flex-shrink: 0;
    background: var(--bg-alt);
    border-radius: var(--radius-sm);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--accent);
  }

  .encart__footer {
