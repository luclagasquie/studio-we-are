---
import { getCollection, render } from 'astro:content';
import PageLayout from '../../layouts/PageLayout.astro';
import Badge from '../../components/ui/Badge.astro';
import Button from '../../components/ui/Button.astro';

export async function getStaticPaths() {
  const projects = await getCollection('projets');
  return projects.map((p) => ({
    params: { slug: p.data.slug },
    props: { project: p },
  }));
}

const { project } = Astro.props;
const { Content } = await render(project);
const d = project.data;

const projectUrl = `https://we-are.fr/projets/${d.slug}/`;

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: d.title,
  description: d.description,
  url: projectUrl,
  author: {
    '@type': 'Person',
    name: 'Luc Lagasquie',
  },
  publisher: {
    '@type': 'Organization',
    name: 'Studio We Are',
    url: 'https://we-are.fr',
  },
};
---
<PageLayout
  title={`${d.title} — Réalisation — Studio We Are`}
  description={d.description}
  jsonLd={jsonLd}
  noindex
>
  <article>
    <!-- Case study header -->
    <header class="case-header section--alt">
      <div class="container case-header__inner">
        <div class="animate-slide">
          <a href="/projets" class="case-back">← Tous les projets</a>
          <p class="case-sector">{d.secteur}</p>
          <h1 class="case-title">{d.title}</h1>
          <p class="case-lieu"><svg class="case-lieu-icon" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 1 1 16 0Z"/><circle cx="12" cy="10" r="3"/></svg>{d.lieu}</p>
          <p class="case-desc">{d.description}</p>
          <div class="case-badges">
            {d.design && <Badge label="Design" />}
            {d.developpement && <Badge label="Développement" />}
            {d.venteEnLigne && <Badge label="E-commerce" />}
            {d.collaborateur && d.collaborateur.length > 0 && (
              <Badge label={d.collaborateur} variant="collaborateur" />
            )}
          </div>
        </div>
      </div>
    </header>

    <!-- Case study body -->
    <section class="section">
      <div class="container">
        <div class="case-content">
          <Content />
        </div>
      </div>
    </section>

    <!-- CTA -->
    <section class="section section--alt">
      <div class="container case-cta animate-slide">
        <div class="case-cta__text">
          <h2 class="case-cta__title">Vous avez un projet similaire ?</h2>
          <p>Parlons de vos besoins — je vous donnerai un avis honnête sur la meilleure approche.</p>
        </div>
        <Button href="/contact" variant="primary" size="lg">Prendre contact</Button>
      </div>
    </section>
  </article>
</PageLayout>

<style>
  .case-header {
    padding-block: var(--space-xl);
  }

  .case-header__inner {
    max-width: var(--content-width);
  }

  .case-back {
    font-size: var(--text-s);
    color: var(--text-muted);
    display: inline-block;
    margin-bottom: 2rem;
    transition: color var(--transition);
  }

  .case-back:hover {
    color: var(--accent);
  }

  .case-sector {
    font-size: 0.8125rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: 1rem;
    font-family: var(--font-body);
    font-weight: 500;
    max-width: none;
  }

  .case-title {
    font-size: var(--heading-xl);
    margin-bottom: 1.25rem;
  }

  .case-lieu {
    font-size: var(--text-s);
    letter-spacing: 0.08em;
    color: var(--text-muted);
    font-family: var(--font-body);
    font-weight: 400;
    margin-bottom: 1.25rem;
    display: flex;
    align-items: center;
    gap: 0.35em;
  }

  .case-lieu-icon {
    flex-shrink: 0;
  }

  .case-desc {
    font-size: var(--text-l);
    color: var(--text-muted);
    margin-bottom: 1.5rem;
    line-height: 1.75;
    max-width: none;
  }

  .case-badges {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
    margin-bottom: 1.5rem;
  }

  .case-content {
    max-width: var(--content-width);
  }

  .case-content :global(h2) {
    font-size: var(--heading-xl);
    margin-block: 2.5rem 0.75rem;
  }

  .case-content :global(h3) {
    font-size: var(--heading-l);
    margin-block: 2rem 0.5rem;
  }

  .case-content :global(p) {
    color: var(--text-muted);
    margin-bottom: 1.25rem;
    max-width: none;
    font-size: var(--text-m);
  }

  .case-cta {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 3rem;
    flex-wrap: wrap;
    max-width: var(--content-width);
    padding: 2.5rem;
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    background: var(--bg);
  }

  .case-cta__title {
    font-size: 1.5rem;
    margin-bottom: 0.5rem;
  }

  .case-cta__text p {
    color: var(--text-muted);
    font-size: var(--text-m);
    max-width: none;
  }
</style>
